{
  "name": "nestjs-scoped-repository",
  "version": "0.1.0",
  "description": "TypeORM ScopedRepository with fortress pattern for NestJS — automatic multi-scope isolation (organisation, user, agent, tenant) on every query",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "nestjs",
    "typeorm",
    "multi-tenant",
    "scoped-repository",
    "repository-pattern",
    "row-level-security",
    "tenant-isolation"
  ],
  "author": "Freerk Kalsbeek",
  "license": "MIT",
  "peerDependencies": {
    "typeorm": ">=0.3.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "typeorm": "^0.3.17",
    "typescript": "^5.0.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/*.spec.ts"]
  }
}
