{
  "name": "typeorm-scoped-repository",
  "version": "0.1.1",
  "description": "TypeORM ScopedRepository with fortress pattern — automatic multi-scope isolation (organisation, user, agent, tenant) on every query. Framework-agnostic.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./nestjs": {
      "types": "./dist/nestjs.d.ts",
      "default": "./dist/nestjs.js"
    }
  },
  "typesVersions": {
    "*": {
      "nestjs": [
        "./dist/nestjs.d.ts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "typeorm",
    "multi-tenant",
    "scoped-repository",
    "repository-pattern",
    "row-level-security",
    "tenant-isolation",
    "fortress-pattern",
    "nestjs"
  ],
  "author": "Freerk Kalsbeek",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/freerk/typeorm-scoped-repository"
  },
  "peerDependencies": {
    "typeorm": ">=0.3.0",
    "@nestjs/common": ">=10.0.0",
    "@nestjs/typeorm": ">=10.0.0"
  },
  "peerDependenciesMeta": {
    "@nestjs/common": {
      "optional": true
    },
    "@nestjs/typeorm": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@nestjs/common": "^11.1.17",
    "@nestjs/core": "^11.1.17",
    "@nestjs/typeorm": "^11.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "better-sqlite3": "^12.8.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "jest": "^29.5.0",
    "prettier": "^3.4.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "ts-jest": "^29.1.0",
    "typeorm": "^0.3.17",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/*.spec.ts"
    ]
  }
}
